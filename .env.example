# Public Supabase browser-safe values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values. Never expose these to client components or browser code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VAULT_KEY_ID=

# Optional server-side provider defaults for local development.
# Production BYOK values should be stored encrypted in Supabase Vault.
OPENAI_API_KEY=
GEMINI_API_KEY=

# App settings.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=local
